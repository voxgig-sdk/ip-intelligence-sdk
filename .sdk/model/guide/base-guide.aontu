# Guide

guide: {
  metrics: count: entity: 2
  metrics: count: path: 2
  metrics: count: method: 2

  entity: api: {
    path: "/api/{ip}": {
      rename: param: "ip": *"id"
      op: load: method: *GET
    }
  }

  entity: usage: {
    path: "/api/usage": {
      op: load: method: *GET
    }
  }

}